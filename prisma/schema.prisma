datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  archetype   String
  strategy    String
  risk        String
  winRate     String   @default("0%")
  color       String   @default("#66e3ff")
  owner       String   @default("Arena Labs")
  wallet      String   @default("0x000...0000")
  bio         String   @default("")
  traits      String   @default("[]") // JSON string field for SQLite
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competitions CompetitionAgent[]
  trades       Trade[]
}

model Competition {
  id              String   @id @default(cuid())
  title           String
  mode            String   // "1v1" | "royale"
  status          String   // "live" | "open" | "settled"
  durationSeconds Int      @default(3600) // actual duration in seconds
  duration        String   // human-readable display string
  countdown       String
  entryFee        String
  prizePool       String
  spectators      Int      @default(0)
  volumeUsd       Float    @default(0)   // FIX 1.2: raw number, formatted on display
  track           String
  premise         String
  winnerId        String?               // FIX 3.2: set on settle
  startedAt       DateTime?             // FIX 3.1: when competition went live
  isTicking       Boolean  @default(false) // FIX 2.2: prevent concurrent ticks
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agents  CompetitionAgent[]
  trades  Trade[]
}

model CompetitionAgent {
  id               String      @id @default(cuid())
  competitionId    String
  agentId          String
  pnl              Float       @default(0)   // $ absolute gain/loss
  pnlPct           Float       @default(0)   // FIX 1.1: % relative to startingPortfolio
  portfolio        Float       @default(10)  // current portfolio value in $
  startingPortfolio Float      @default(10)  // FIX 1.1: baseline for % calc
  trades           Int         @default(0)
  score            Int         @default(0)   // FIX 1.4: uncapped, use dynamic max

  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent         Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([competitionId, agentId])
}

model Trade {
  id            String      @id @default(cuid())
  competitionId String
  agentId       String
  type          String      // "BUY" | "SELL" | "HOLD"
  pair          String
  amount        String
  amountUsd     Float       @default(0)   // FIX 1.2: raw $ for volume tracking
  rationale     String
  priceImpact   String
  timestamp     DateTime    @default(now()) // FIX 1.3: source of truth for time

  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent         Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
