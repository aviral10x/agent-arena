datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  archetype   String
  strategy    String
  risk        String
  winRate     String   @default("0%")
  color       String   @default("#66e3ff")
  owner       String   @default("Arena Labs")
  wallet      String   @default("0x000...0000")
  bio         String   @default("")
  traits      String   @default("[]")
  walletKey   String?  // encrypted private key for on-chain execution (null = simulated mode)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  competitions CompetitionAgent[]
  trades       Trade[]
  signals      Signal[]           // Phase 6: signal marketplace
}

model Competition {
  id              String    @id @default(cuid())
  title           String
  mode            String    // "1v1" | "royale"
  status          String    // "live" | "open" | "settled"
  durationSeconds Int       @default(3600)
  duration        String
  countdown       String
  entryFee        String
  prizePool       String
  spectators      Int       @default(0)
  volumeUsd       Float     @default(0)
  track           String
  premise         String
  winnerId        String?
  startedAt       DateTime?
  isTicking       Boolean   @default(false)
  // Phase 6: matchmaking — who issued the challenge
  challengerId    String?   // agentId of the challenger (matchmaking)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agents   CompetitionAgent[]
  trades   Trade[]
  signals  Signal[]           // Phase 6
}

model CompetitionAgent {
  id                String  @id @default(cuid())
  competitionId     String
  agentId           String
  pnl               Float   @default(0)
  pnlPct            Float   @default(0)
  portfolio         Float   @default(10)
  startingPortfolio Float   @default(10)
  trades            Int     @default(0)
  score             Int     @default(0)

  competition  Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent        Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([competitionId, agentId])
}

model Trade {
  id            String   @id @default(cuid())
  competitionId String
  agentId       String
  type          String   // "BUY" | "SELL" | "HOLD"
  pair          String
  amount        String
  amountUsd     Float    @default(0)
  rationale     String
  priceImpact   String
  timestamp     DateTime @default(now())

  competition  Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  agent        Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// Phase 6: x402 access grants — server-side record of paid access
model AccessGrant {
  id            String   @id @default(cuid())
  walletAddress String
  resourceType  String   // "leaderboard" | "replay" | "signal"
  resourceId    String   // competitionId or signalId
  txSignature   String   // EIP-3009 signature used (prevents replay)
  amountUsd     Float
  grantedAt     DateTime @default(now())
  expiresAt     DateTime // access TTL

  @@unique([walletAddress, resourceType, resourceId])
  @@index([walletAddress, resourceType])
}

// Phase 6: signal marketplace
model Signal {
  id            String   @id @default(cuid())
  agentId       String
  competitionId String
  tradeType     String   // "BUY" | "SELL"
  pair          String
  rationale     String
  priceAtSignal Float    @default(0)
  priceUsd      Float    @default(1)   // cost to unlock in USDC
  unlockCount   Int      @default(0)
  createdAt     DateTime @default(now())

  agent        Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  competition  Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
}
